<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ADVulture — Posture Report: {{ report.domain }}</title>
<style>
  :root {
    --bg: #0f1117; --surface: #1a1d2e; --surface2: #252840;
    --text: #e2e8f0; --text-muted: #94a3b8; --border: #2d3154;
    --critical: #ef4444; --high: #f97316; --medium: #eab308;
    --low: #22c55e; --info: #3b82f6;
    --ordered: #22c55e; --critical-regime: #eab308; --chaotic: #ef4444;
    --class-a: #8b5cf6; --class-b: #3b82f6; --class-c: #06b6d4;
    --class-d: #ef4444; --class-e: #f97316; --class-f: #ec4899;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px; }
  .container { max-width: 1200px; margin: 0 auto; padding: 24px; }
  h1 { font-size: 28px; font-weight: 700; color: #f1f5f9; }
  h2 { font-size: 18px; font-weight: 600; color: #cbd5e1; margin-bottom: 16px; }
  h3 { font-size: 15px; font-weight: 600; color: #94a3b8; margin-bottom: 8px; }
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
  .header-meta { color: var(--text-muted); font-size: 13px; }
  .logo { font-size: 36px; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 24px; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
  .metric-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 6px; }
  .metric-value { font-size: 32px; font-weight: 700; }
  .metric-sub { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .regime-ORDERED { color: var(--ordered); }
  .regime-CRITICAL { color: var(--critical-regime); }
  .regime-CHAOTIC { color: var(--chaotic); }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
  .badge-CRITICAL { background: rgba(239,68,68,0.15); color: var(--critical); }
  .badge-HIGH { background: rgba(249,115,22,0.15); color: var(--high); }
  .badge-MEDIUM { background: rgba(234,179,8,0.15); color: var(--medium); }
  .badge-LOW { background: rgba(34,197,94,0.15); color: var(--low); }
  .badge-class-A { background: rgba(139,92,246,0.15); color: var(--class-a); }
  .badge-class-B { background: rgba(59,130,246,0.15); color: var(--class-b); }
  .badge-class-C { background: rgba(6,182,212,0.15); color: var(--class-c); }
  .badge-class-D { background: rgba(239,68,68,0.15); color: var(--class-d); }
  .badge-class-E { background: rgba(249,115,22,0.15); color: var(--class-e); }
  .badge-class-F { background: rgba(236,72,153,0.15); color: var(--class-f); }
  .active-signal { color: #fbbf24; font-size: 11px; }
  .finding-row { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px; margin-bottom: 10px; }
  .finding-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; flex-wrap: wrap; }
  .finding-title { font-weight: 600; font-size: 14px; flex: 1; }
  .finding-evidence { font-size: 12px; color: var(--text-muted); margin-top: 6px; }
  .finding-remediation { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
  .finding-remediation ol { padding-left: 18px; }
  .finding-remediation li { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
  .gradient-bar { display: flex; align-items: center; gap: 8px; }
  .gradient-track { flex: 1; height: 4px; background: var(--surface2); border-radius: 2px; overflow: hidden; }
  .gradient-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #ef4444); border-radius: 2px; }
  .gradient-label { font-size: 11px; color: var(--text-muted); min-width: 40px; text-align: right; }
  .rank-table { width: 100%; border-collapse: collapse; }
  .rank-table th { text-align: left; padding: 8px 12px; font-size: 11px; text-transform: uppercase; color: var(--text-muted); border-bottom: 1px solid var(--border); }
  .rank-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); font-size: 13px; }
  .rank-table tr:last-child td { border-bottom: none; }
  .section { margin-bottom: 32px; }
  .counts-grid { display: flex; gap: 12px; flex-wrap: wrap; }
  .count-chip { background: var(--surface2); border-radius: 6px; padding: 8px 14px; }
  .count-chip .letter { font-weight: 700; font-size: 16px; }
  .count-chip .number { color: var(--text-muted); font-size: 13px; }
  .explanation { font-size: 12px; color: var(--text-muted); margin-top: 8px; }
  footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 11px; text-align: center; }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header">
    <div>
      <div class="logo">🦅</div>
      <h1>ADVulture Posture Report</h1>
      <div class="header-meta">
        Domain: {{ report.domain }} &nbsp;|&nbsp;
        Type: {{ report.deployment_type }} &nbsp;|&nbsp;
        Generated: {{ report.timestamp.strftime('%Y-%m-%d %H:%M UTC') }}
      </div>
    </div>
  </div>

  <!-- Key Metrics -->
  <div class="grid-3">
    <div class="card">
      <div class="metric-label">Regime</div>
      <div class="metric-value regime-{{ report.regime }}">{{ report.regime }}</div>
      <div class="metric-sub">{{ report.regime_explanation[:80] }}...</div>
    </div>
    <div class="card">
      <div class="metric-label">Steady-State π_tier0</div>
      <div class="metric-value" style="color: {% if report.tier0_steady_state_probability > 0.3 %}var(--critical){% elif report.tier0_steady_state_probability > 0.15 %}var(--medium){% else %}var(--low){% endif %}">
        {{ "%.1f"|format(report.tier0_steady_state_probability * 100) }}%
      </div>
      <div class="metric-sub">Long-run Tier 0 compromise probability</div>
    </div>
    <div class="card">
      <div class="metric-label">Mean Steps to Domain Admin</div>
      <div class="metric-value" style="color: {% if report.mean_steps_to_tier0 < 5 %}var(--critical){% elif report.mean_steps_to_tier0 < 15 %}var(--medium){% else %}var(--low){% endif %}">
        {{ "%.1f"|format(report.mean_steps_to_tier0) }}
      </div>
      <div class="metric-sub">Markov mean first passage time</div>
    </div>
  </div>

  <div class="grid-3">
    <div class="card">
      <div class="metric-label">Attacker Phase</div>
      <div class="metric-value" style="font-size: 20px; padding-top: 6px;">
        {% if report.attacker_phase %}{{ report.attacker_phase.most_likely.name }}{% else %}UNKNOWN{% endif %}
      </div>
      <div class="metric-sub">
        {% if report.attacker_phase %}
        Confidence: {{ "%.0f"|format(report.attacker_phase.confidence * 100) }}% &nbsp;|&nbsp;
        Velocity: {{ "%.2f"|format(report.attacker_phase.threat_velocity) }}
        {% endif %}
      </div>
    </div>
    <div class="card">
      <div class="metric-label">Total Findings</div>
      <div class="metric-value">{{ report.findings|length }}</div>
      <div class="metric-sub">{{ report.active_signals|length }} with active signals</div>
    </div>
    <div class="card">
      <div class="metric-label">By Risk Class</div>
      <div class="counts-grid" style="margin-top: 8px;">
        {% for cls, cnt in report.finding_counts.items() %}
        <div class="count-chip">
          <span class="letter" style="color: var(--class-{{ cls|lower }})">{{ cls }}</span>
          <span class="number"> {{ cnt }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- Remediation Ranking -->
  <div class="section">
    <div class="card">
      <h2>Remediation Ranking — ∂π_tier0/∂θ</h2>
      <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">
        Ordered by gradient magnitude × phase relevance. Controls with highest gradient most efficiently reduce steady-state Tier 0 compromise probability.
      </p>
      <table class="rank-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Control</th>
            <th>Gradient</th>
            <th>Risk Classes</th>
            <th>Current</th>
            <th>Explanation</th>
          </tr>
        </thead>
        <tbody>
          {% for item in report.remediation_ranking[:15] %}
          <tr>
            <td style="color:var(--text-muted);font-weight:600;">{{ loop.index }}</td>
            <td style="font-weight:600;">{{ item.control }}</td>
            <td>
              <div class="gradient-bar">
                <div class="gradient-track">
                  <div class="gradient-fill" style="width:{{ [item.gradient * 100, 100]|min }}%"></div>
                </div>
                <div class="gradient-label">{{ "%.3f"|format(item.gradient) }}</div>
              </div>
            </td>
            <td>
              {% for cls in item.risk_classes_affected %}
              <span class="badge badge-class-{{ cls }}">{{ cls }}</span>
              {% endfor %}
            </td>
            <td style="color:var(--text-muted);">{{ "%.0f"|format(item.current_value * 100) }}%</td>
            <td style="font-size:12px;color:var(--text-muted);max-width:300px;">{{ item.explanation[:100] }}...</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Findings -->
  <div class="section">
    <h2>Unified Findings — All Risk Classes</h2>
    {% for finding in report.findings %}
    <div class="finding-row">
      <div class="finding-header">
        <span class="badge badge-class-{{ finding.risk_class.value }}">
          {{ finding.risk_class.value }} — {{ finding.risk_class.label }}
        </span>
        <span class="badge badge-{{ finding.severity.value }}">{{ finding.severity.value }}</span>
        {% if finding.active_signal %}
        <span class="active-signal">⚠ ACTIVE SIGNAL</span>
        {% endif %}
        <span style="font-size:11px;color:var(--text-muted);">
          ∂/∂θ {{ "%.3f"|format(finding.gradient_contribution) }}
        </span>
        <div class="finding-title">{{ finding.title }}</div>
      </div>

      {% if finding.evidence_detail %}
      <div class="finding-evidence">{{ finding.evidence_detail }}</div>
      {% endif %}

      <div style="margin-top:8px;font-size:11px;color:var(--text-muted);">
        Evidence: {{ finding.evidence_sources|join(', ') }}
        {% if finding.mitre_techniques %}
        &nbsp;|&nbsp; MITRE: {{ finding.mitre_techniques|join(', ') }}
        {% endif %}
      </div>

      {% if finding.remediation_steps %}
      <div class="finding-remediation">
        <h3>Remediation</h3>
        <ol>
          {% for step in finding.remediation_steps %}
          <li>{{ step }}</li>
          {% endfor %}
        </ol>
      </div>
      {% endif %}

      {% if finding.breaks_if_changed %}
      <div style="margin-top:8px;font-size:12px;color:var(--medium);">
        ⚠ Dependency: remediating this may affect {{ finding.breaks_if_changed|join(', ') }}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <!-- Active Signals -->
  {% if report.active_signals %}
  <div class="section">
    <div class="card">
      <h2>Active Signals</h2>
      {% for signal in report.active_signals %}
      <div style="padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;">
        <span class="active-signal">⚠</span> {{ signal }}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <footer>
    ADVulture v{{ version }} &nbsp;|&nbsp;
    Inspired by BloodHound (SpecterOps) and Digital Ecosystems (Sakana AI, 2026) &nbsp;|&nbsp;
    For authorised security assessment use only
  </footer>

</div>
</body>
</html>
