{
  "manifest_version": 3,
  "name": "BAI",
  "version": "0.9.1",
  "description": "BAI: local forensic acquisition of Chrome profile artifacts with SHA-256 hashing and a sealed evidence manifest. © 2026, Shane Shook, All Rights Reserved - this tool is for testing and analysis.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Acquisition Console",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "history",
    "cookies",
    "downloads",
    "tabs",
    "pageCapture",
    "storage",
    "bookmarks",
    "management",
    "sessions",
    "topSites",
    "proxy",
    "privacy",
    "contentSettings",
    "search",
    "scripting",
    "identity",
    "system.cpu",
    "system.memory",
    "system.storage",
    "readingList"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
